{
  "name": "@forgetful-fish/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --watch --watch-path=src --watch-preserve-output --import tsx src/index.ts",
    "start": "node --import tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@fastify/websocket": "^11.2.0",
    "@forgetful-fish/database": "workspace:*",
    "@forgetful-fish/game-engine": "workspace:*",
    "@forgetful-fish/realtime-contract": "workspace:*",
    "fastify": "^5.7.4",
    "ws": "^8.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/ws": "^8.18.1",
    "tsx": "^4.21.0"
  }
}
