{
  "name": "@forgetful-fish/database",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "scripts": {
    "build": "cross-env PRISMA_HIDE_UPDATE_MESSAGE=true prisma generate --no-hints",
    "lint": "eslint .",
    "typecheck": "cross-env DATABASE_URL=postgresql://postgres:postgres@localhost:5432/forgetful_fish PRISMA_HIDE_UPDATE_MESSAGE=true prisma generate --no-hints && cross-env DATABASE_URL=postgresql://postgres:postgres@localhost:5432/forgetful_fish PRISMA_HIDE_UPDATE_MESSAGE=true prisma validate",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest --passWithNoTests",
    "db:generate": "cross-env PRISMA_HIDE_UPDATE_MESSAGE=true prisma generate --no-hints",
    "db:migrate:deploy": "cross-env PRISMA_HIDE_UPDATE_MESSAGE=true prisma migrate deploy",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.4.1",
    "@prisma/client": "^7.4.1"
  },
  "devDependencies": {
    "@types/pg": "^8.15.6",
    "cross-env": "^10.1.0",
    "dotenv": "^17.2.3",
    "pg": "^8.16.3",
    "prisma": "^7.4.1"
  }
}
